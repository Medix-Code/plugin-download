{
  "manifest_version": 3,
  "name": "Descarregador d'Imatges",
  "version": "1.10.6",
  "description": "Descarrega les imatges visibles de la pestanya actual per proves internes.",
  "permissions": [
    "downloads",
    "scripting",
    "activeTab",
    "storage",
    "offscreen"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Descarrega les imatges de la pestanya actual",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
